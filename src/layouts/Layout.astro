---
import "../index.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title = "Dyallab | Your growth, engineered",
  description = "Dyallab is a technology consultancy focused on software engineering, application security and infrastructure.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/dyallab-logo.png" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Calendly widget styles -->
    <link
      href="https://assets.calendly.com/assets/external/widget.css"
      rel="stylesheet"
    />
  </head>
  <body class="text-dyallab-text-secondary antialiased">
    <!-- Animated background layer -->
    <div class="bg-animated" aria-hidden="true"></div>

    <slot />

    <!-- Calendly widget -->
    <script
      is:inline
      src="https://assets.calendly.com/assets/external/widget.js"></script>
  </body>
</html>
