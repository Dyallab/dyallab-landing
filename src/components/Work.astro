---
const projects = [
  {
    name: "IoT in Motion",
    description: "Infrastructure and platform consulting for IoT connectivity.",
    link: "https://iotinmotion.com.ar",
    tags: ["Infrastructure", "IoT", "Platform"],
  },
  {
    name: "INTI",
    description: "Mentorship on quality systems and industrial innovation.",
    link: "https://www.argentina.gob.ar/inti",
    tags: ["Metrology", "Quality Certification", "Innovation"],
  },
  {
    name: "MainHost",
    description: "Platform architecture and hosting infrastructure.",
    link: "https://mainhost.dyallab.com.ar",
    tags: ["Infrastructure", "Hosting"],
  },
  {
    name: "HenKaiPan",
    description: "Security platform engineering and development.",
    link: "https://henkaipan.dyallab.com.ar",
    tags: ["Security", "Vulnerability Management"],
  },
  {
    name: "Instituto Web",
    description: "QA and testing course mentorship.",
    link: "https://www.institutoweb.com.ar",
    tags: ["Education", "QA", "Testing"],
  },
  {
    name: "Frontend Cafe",
    description: "Workshop facilitation and community mentorship.",
    link: "https://frontend.cafe",
    tags: ["Community", "Frontend", "Education"],
  },
  {
    name: "Rust Lang ES",
    description: "DevOps and infrastructure for the Rust Spanish community.",
    link: "https://rustlang-es.org",
    tags: ["Community", "DevOps", "Rust"],
  },
];
---

<section id="work" class="py-28">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Section header -->
    <div class="mb-16">
      <p
        class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-dyallab-muted"
      >
        Selected Work
      </p>
      <h2
        class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl"
      >
        Clients and collaborations
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-2xl border border-dyallab-border bg-white p-8 transition-colors hover:bg-dyallab-surface sm:p-10"
          >
            <h3 class="text-lg font-semibold text-gray-900 transition-colors group-hover:text-dyallab-accent">
              {project.name}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-dyallab-text-secondary">
              {project.description}
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-full border border-dyallab-border px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-dyallab-muted">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
