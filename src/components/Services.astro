---
const services = [
  {
    name: "Infrastructure",
    description:
      "Server administration, network configuration and system maintenance.",
  },
  {
    name: "Application Security",
    description: "Threat modeling, DevSecOps tooling and penetration testing.",
  },
  {
    name: "DevOps & DevSecOps",
    description: "Security automation, compliance as code and CI/CD security.",
  },
  {
    name: "Architecture Solutions",
    description:
      "Microservices, event-driven architecture and distributed systems.",
  },
  {
    name: "AI & Software Development",
    description: "AI agents, chatbots, MCP implementation and custom software.",
  },
  {
    name: "Embedded Systems & Hardware",
    description:
      "Embedded development, IoT devices and hardware-software integration.",
  },
];
---

<section id="services" class="border-t border-dyallab-border py-28">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Section header -->
    <div class="mb-16">
      <p
        class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-dyallab-muted"
      >
        Services
      </p>
      <h2
        class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl"
      >
        What we do
      </h2>
    </div>

    <!-- Cards -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <div class="rounded-2xl border border-dyallab-border bg-dyallab-bg p-8 transition-colors hover:bg-dyallab-surface sm:p-10">
            <h3 class="text-lg font-semibold text-gray-900">{service.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-dyallab-text-secondary">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
