---
const services = [
  {
    name: "Cloud, Infrastructure & DevOps",
    description:
      "Designing scalable, high-availability platforms. We automate provisioning through Infrastructure as Code (IaC), optimize network topology, and build secure, self-healing CI/CD pipelines for continuous delivery.",
  },
  {
    name: "Application & Product Security",
    description:
      "End-to-end software security posture. We implement threat modeling, advanced penetration testing, and automated secure code analysis (SAST/DAST/SCA) to embed proactive defense and compliance directly into the engineering lifecycle.",
  },
  {
    name: "Software Engineering & AI Solutions",
    description:
      "Engineering distributed, high-scale systems integrated with production-ready AI. We build event-driven microservices and agentic workflows utilizing MCP to bridge the gap between Large Language Models, custom enterprise software, and secure data layers.",
  },
];
---

<section id="services" class="border-t border-dyallab-border py-28">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Section header -->
    <div class="mb-16">
      <p
        class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-dyallab-muted"
      >
        Services
      </p>
      <h2
        class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl"
      >
        What we do
      </h2>
    </div>

    <!-- Cards -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <div class="rounded-2xl border border-dyallab-border bg-white p-8 transition-colors hover:bg-dyallab-surface sm:p-10">
            <h3 class="text-lg font-semibold text-gray-900">{service.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-dyallab-text-secondary">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
