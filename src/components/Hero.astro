---

---

<section class="relative flex min-h-screen items-center justify-center">
  <div class="mx-auto max-w-3xl px-6 pb-20 pt-16 text-center">
    <!-- Logo -->
    <div class="mb-4 flex justify-center">
      <img
        src="/dyallab-2.png"
        alt="Dyallab"
        class="h-64 w-64 object-contain sm:h-72 sm:w-72"
      />
    </div>

    <!-- Headline -->
    <h1
      class="text-4xl font-semibold leading-tight tracking-tight text-gray-900 sm:text-5xl md:text-6xl lg:text-7xl"
    >
      Your growth,<br />
      <span class="text-dyallab-accent">engineered.</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="mt-8 font-mono text-xs font-medium uppercase tracking-[0.25em] text-gray-400 sm:text-sm"
    >
      Build &middot; Secure &middot; Ship
    </p>

    <!-- Ghost Buttons -->
    <div class="mt-14 flex items-center justify-center gap-4">
      <a
        href="https://calendly.com/dyallo/discovery-call"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-10 items-center rounded-full border border-gray-900 px-6 text-sm font-medium text-gray-900 transition-colors hover:border-dyallab-accent hover:text-dyallab-accent"
      >
        Schedule a call
      </a>
      <a
        href="mailto:contact@dyallab.com.ar"
        class="inline-flex h-10 items-center rounded-full border border-gray-900 px-6 text-sm font-medium text-gray-900 transition-colors hover:border-dyallab-accent hover:text-dyallab-accent"
      >
        Contact
      </a>
    </div>
  </div>
</section>
